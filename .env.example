# Infinity HRMS — environment template
# Copy to .env (gitignored) and fill in real values.
# Generate strong secrets with:  openssl rand -hex 32

# ── Public-facing ────────────────────────────────────────────────────
# Domain Caddy will issue Let's Encrypt for and proxy to the Frappe stack.
# For local dev, point DNS at the Hetzner VPS first or use a *.test name.
DOMAIN=hrms.infinitynexatech.com

# Frappe site name. MUST equal DOMAIN in production — Frappe routes by Host.
SITE_NAME=hrms.infinitynexatech.com

# ── Database ─────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=replace-with-openssl-rand-hex-24
DB_PASSWORD=replace-with-openssl-rand-hex-24

# ── Frappe ───────────────────────────────────────────────────────────
# First-boot admin password (user: Administrator)
ADMIN_PASSWORD=replace-with-strong-password

# Encryption key for stored secrets (Frappe sites/<site>/site_config.json)
# MUST be 32-byte hex. openssl rand -hex 32
ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# ── Upstream pins ────────────────────────────────────────────────────
# All three must match (Frappe ecosystem is version-locked across apps).
FRAPPE_VERSION=version-15
ERPNEXT_VERSION=version-15
HRMS_VERSION=version-15

# Docker image tag for the custom build (used in compose files).
# Bump when you rebuild: e.g. v1.0.1 after a branding tweak.
IMAGE_TAG=v1.0.0
